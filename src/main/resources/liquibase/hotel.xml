<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <changeSet id="1" author="Arslan Kalaitsidis">
        <createTable tableName="hotels">
            <column name="id" autoIncrement="true" type="bigint"><constraints primaryKey="true" /> </column>
            <column name="hotel_url" type="varchar(255)"><constraints nullable="false" /></column>
            <column name="hotel_name" type="varchar(255)"><constraints nullable="false" /></column>
            <column name="hotel_description" type="varchar(1000)"><constraints nullable="false" /> </column>
            <column name="address" type="varchar(255)"><constraints nullable="false" /></column>
            <column name="city" type="varchar(255)"><constraints nullable="false" /></column>
            <column name="longitude" type="float(23)"><constraints nullable="true" /></column>
            <column name="latitude" type="float(23)"><constraints nullable="true" /></column>
            <column name="hotel_type" type="enum ('APART_HOTEL','GUEST_HOUSE','HOLIDAY_HOME','HOTEL','PRIVATE_HOST')"><constraints nullable="false" /></column>
            <column name="hotel_score" type="decimal(4,2)">
                <constraints nullable="false" checkConstraint="(hotel_score IS NULL OR (hotel_score &gt;= 0 AND hotel_score &lt;= 10.0))" />
            </column>
        </createTable>
        <modifySql dbms="mysql">
            <append value="ENGINE=INNODB CHARSET=UTF8 COLLATE utf8_unicode_520_ci"/>
        </modifySql>
    </changeSet>
    <changeSet id="2" author="Arslan Kalaitsidis">
        <addUniqueConstraint tableName="hotels" columnNames="hotel_url" constraintName="HOTELS_UNIQUE_URL" />
    </changeSet>

    <changeSet id="3" author="Arslan Kalaitsidis" context="data">
        <loadData tableName="hotels" file="data/hotel.csv" />
    </changeSet>
</databaseChangeLog>