## Optional: enable real emails via SendGrid
## Fill these values and keep this file PRIVATE.
## Copy to ".env" (same folder) and set the values there.

## Profiles:
## - dev: no-op email (token is logged)
## - dev,default: SendGrid emails enabled
SPRING_PROFILES_ACTIVE=dev

# Required for email sending
SEND_GRID_API_KEY=

# Optional: override the From address (must be verified in SendGrid)
SEND_GRID_FROM=
